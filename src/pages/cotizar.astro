---
import Layout from '../layouts/Layout.astro';
import { getImage } from "astro:assets";
import quoteBg from "../assets/images/quote-background.jpg";

const optimizedQuoteBg = await getImage({ src: quoteBg, format: 'avif' });

const countries = [
  { name: "Argentina", flag: "🇦🇷", code: "AR" },
  { name: "Brasil", flag: "🇧🇷", code: "BR" },
  { name: "Chile", flag: "🇨🇱", code: "CL" },
  { name: "Ecuador", flag: "🇪🇨", code: "EC" },
  { name: "Paraguay", flag: "🇵🇾", code: "PY" },
  { name: "Perú", flag: "🇵🇪", code: "PE" },
  { name: "Uruguay", flag: "🇺🇾", code: "UY" },
];
---

<Layout title="Solicitar Cotización - ShipLog">
  <div class="quote-page">
    <div class="quote-background" style={`background-image: url(${optimizedQuoteBg.src});`}></div>
    
    <div class="quote-container">
      <!-- Paso 1: Selección de país -->
      <div id="step1" class="quote-step active">
        <div class="step-header fade-in">
          <h1>¿A dónde necesitas enviar?</h1>
          <p>Selecciona el país de destino para tu carga</p>
        </div>
        
        <div class="countries-selector">
          {countries.map((country, index) => (
            <button 
              class="country-option scale-in" 
              data-country={country.code}
              style={`animation-delay: ${index * 0.05}s`}
            >
              <span class="country-flag">{country.flag}</span>
              <span class="country-name">{country.name}</span>
              <svg class="country-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          ))}
        </div>
      </div>
      
      <!-- Paso 2: Formulario -->
      <div id="step2" class="quote-step">
        <div class="step-header">
          <button class="back-button" id="backBtn">
            <svg width="24" height="24" viewBox="0 0 20 20" fill="none">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Volver</span>
          </button>
          <h1>Completa tu solicitud</h1>
          <p>Envío a <span id="selectedCountry" class="highlight"></span></p>
        </div>
        
        <form class="quote-form" id="quoteForm">
          <div class="form-grid">
            <!-- Datos de Contacto -->
            <div class="form-group">
              <label for="company">Empresa *</label>
              <input type="text" id="company" name="company" required placeholder="Nombre de tu empresa" />
            </div>
            
            <div class="form-group">
              <label for="contact">Nombre de Contacto *</label>
              <input type="text" id="contact" name="contact" required placeholder="Tu nombre completo" />
            </div>
            
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="correo@empresa.com" />
            </div>
            
            <div class="form-group">
              <label for="phone">Teléfono *</label>
              <input type="tel" id="phone" name="phone" required placeholder="+XX XXX XXX XXXX" />
            </div>

            <!-- Detalles del Envío -->
            <div class="form-group">
              <label for="origin">País de Origen *</label>
              <select id="origin" name="origin" required>
                <option value="">Seleccione...</option>
                {countries.map(country => (
                  <option value={country.code}>{country.flag} {country.name}</option>
                ))}
              </select>
            </div>
            
            <div class="form-group">
              <label for="cargoType">Tipo de Carga *</label>
              <select id="cargoType" name="cargoType" required>
                <option value="">Seleccione...</option>
                <option value="maquinaria">🏗️ Maquinaria Pesada</option>
                <option value="construccion">🧱 Materiales de Construcción</option>
                <option value="mineria">⛏️ Equipos Mineros</option>
                <option value="agricola">🌾 Maquinaria Agrícola</option>
                <option value="industrial">🏭 Equipos Industriales</option>
                <option value="otro">📦 Otro</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="serviceType">Tipo de Servicio *</label>
              <select id="serviceType" name="serviceType" required>
                <option value="">Seleccione...</option>
                <option value="puerta-puerta">🏠 Puerta a Puerta</option>
                <option value="puerta-puerto">🛳️ Puerta a Puerto</option>
                <option value="puerto-puerto">⚓ Puerto a Puerto</option>
                <option value="puerto-puerta">🏗️ Puerto a Puerta</option>
              </select>
            </div>

            <div class="form-group">
              <label for="shippingType">Tipo de Envío *</label>
              <select id="shippingType" name="shippingType" required>
                <option value="">Seleccione...</option>
                <option value="aereo">✈️ Aéreo</option>
                <option value="maritimo">🚢 Marítimo</option>
              </select>
            </div>

            <div class="form-group full-width">
              <label for="weight">Peso Estimado (Toneladas) *</label>
              <input type="number" id="weight" name="weight" min="0" step="0.1" required placeholder="0.0" />
            </div>

            <div class="form-group full-width">
              <label for="details">Detalles Adicionales</label>
              <textarea id="details" name="details" rows="3" placeholder="Dimensiones, fechas, etc."></textarea>
            </div>
          </div>
          
          <div class="form-footer">
            <button type="submit" class="btn-submit">
              <span>Enviar Cotización</span>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  .quote-page {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    padding: 8rem 0 4rem;
  }

  .quote-background {
    position: fixed;
    inset: 0;
    background-color: #012e72ff;
    z-index: -2;
  }

  .quote-background::after {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.05) 0%, transparent 50%);
  }

  .quote-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
  }

  .quote-step {
    display: none;
  }

  .quote-step.active {
    display: block;
  }

  .step-header {
    text-align: center;
    margin-bottom: 2.5rem;
    color: white;
  }

  .step-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: white;
    letter-spacing: -1px;
  }

  .step-header p {
    font-size: 1.1rem;
    opacity: 0.9;
  }

  .highlight {
    color: #FFD700;
    font-weight: 700;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.1);
    color: white;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.6rem 1.2rem;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .back-button:hover {
    background: rgba(255,255,255,0.2);
    transform: translateX(-3px);
  }

  .countries-selector {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .country-option {
    background: white;
    border: 2px solid transparent;
    padding: 1.5rem;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  .country-option:hover {
    transform: translateY(-5px);
    border-color: #1e3a8a;
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  .country-flag {
    font-size: 2.5rem;
  }

  .country-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e293b;
  }

  .country-arrow {
    color: #1e3a8a;
    opacity: 0.5;
  }

  .quote-form {
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  label {
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #334155;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  input, select, textarea {
    padding: 0.85rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #f8fafc;
    color: #1e293b;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: #1e3a8a;
    box-shadow: 0 0 0 3px rgba(30,58,138,0.1);
    background: white;
  }

  textarea {
    resize: vertical;
    min-height: 80px;
  }

  select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%231e3a8a' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .form-footer {
    margin-top: 2rem;
  }

  .btn-submit {
    width: 100%;
    background: #1e3a8a;
    color: white;
    padding: 1.1rem;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .btn-submit:hover {
    background: #1e40af;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .quote-page {
      padding: 6rem 0 2rem;
    }

    .step-header h1 {
      font-size: 2.2rem;
    }

    .countries-selector {
      grid-template-columns: 1fr;
    }

    .country-option {
      flex-direction: row;
      padding: 1rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .quote-form {
      padding: 1.5rem;
    }
  }
</style>

<script>
  let selectedDestination = '';

  document.addEventListener('DOMContentLoaded', () => {
    const step1 = document.getElementById('step1');
    const step2 = document.getElementById('step2');
    const countryOptions = document.querySelectorAll('.country-option');
    const backBtn = document.getElementById('backBtn');
    const selectedCountrySpan = document.getElementById('selectedCountry');
    const quoteForm = document.getElementById('quoteForm');

    countryOptions.forEach(option => {
      option.addEventListener('click', () => {
        const countryCode = option.getAttribute('data-country');
        const countryName = option.querySelector('.country-name')?.textContent;
        const countryFlag = option.querySelector('.country-flag')?.textContent;
        
        selectedDestination = countryCode || '';
        if (selectedCountrySpan && countryName && countryFlag) {
          selectedCountrySpan.textContent = `${countryFlag} ${countryName}`;
        }
        
        step1?.classList.remove('active');
        step2?.classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    backBtn?.addEventListener('click', () => {
      step2?.classList.remove('active');
      step1?.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    quoteForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert(`¡Solicitud enviada! Nos contactaremos contigo pronto.`);
      window.location.href = '/';
    });
  });
</script>
