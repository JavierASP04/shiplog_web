---
import Layout from '../layouts/Layout.astro';
import { getImage } from "astro:assets";
import quoteBg from "../assets/images/quote-background.jpg";

const optimizedQuoteBg = await getImage({ src: quoteBg, format: 'avif' });

const countries = [
  { name: "Argentina", flag: "🇦🇷", code: "AR" },
  { name: "Brasil", flag: "🇧🇷", code: "BR" },
  { name: "Chile", flag: "🇨🇱", code: "CL" },
  { name: "Ecuador", flag: "🇪🇨", code: "EC" },
  { name: "Paraguay", flag: "🇵🇾", code: "PY" },
  { name: "Perú", flag: "🇵🇪", code: "PE" },
  { name: "Uruguay", flag: "🇺🇾", code: "UY" },
];
---

<Layout title="Solicitar Cotización - ShipLog">
  <div class="quote-page">
    <div class="quote-background" style={`background-image: url(${optimizedQuoteBg.src});`}></div>
    
    <div class="quote-container">
      <!-- Paso 1: Selección de país -->
      <div id="step1" class="quote-step active">
        <div class="step-header fade-in">
          <h1>¿A dónde necesitas enviar?</h1>
          <p>Selecciona el país de destino para tu carga</p>
        </div>
        
        <div class="countries-selector">
          {countries.map((country, index) => (
            <button 
              class="country-option scale-in" 
              data-country={country.code}
              style={`animation-delay: ${index * 0.05}s`}
            >
              <span class="country-flag">{country.flag}</span>
              <span class="country-name">{country.name}</span>
              <svg class="country-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          ))}
        </div>
      </div>
      
      <!-- Paso 2: Formulario -->
      <div id="step2" class="quote-step">
        <div class="step-header">
          <button class="back-button" id="backBtn">
            <svg width="24" height="24" viewBox="0 0 20 20" fill="none">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Volver</span>
          </button>
          <h1>Completa tu solicitud</h1>
          <p>Envío a <span id="selectedCountry" class="highlight"></span></p>
        </div>
        
        <form class="quote-form" id="quoteForm">
          <div class="form-grid">
            <!-- Datos de Contacto -->
            <div class="form-group">
              <label for="company">Empresa *</label>
              <input type="text" id="company" name="01_Empresa" required placeholder="Nombre de tu empresa" />
            </div>
            
            <div class="form-group">
              <label for="contact">Nombre de Contacto *</label>
              <input type="text" id="contact" name="02_Contacto" required placeholder="Tu nombre completo" />
            </div>
            
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="03_Email" required placeholder="correo@empresa.com" />
            </div>
            
            <div class="form-group">
              <label for="phone">Teléfono *</label>
              <input type="tel" id="phone" name="04_Telefono" required placeholder="+XX XXX XXX XXXX" />
            </div>

            <!-- Detalles del Envío -->
            <div class="form-group">
              <label for="origin">País de Origen *</label>
              <select id="origin" name="05_Pais_Origen" required>
                <option value="">Seleccione...</option>
                {countries.map(country => (
                  <option value={country.name}>{country.flag} {country.name}</option>
                ))}
              </select>
            </div>

            <div class="form-group full-width">
              <label for="shippingType">Tipo de Envío *</label>
              <select id="shippingType" name="06_Tipo_Transporte" required>
                <option value="">Seleccione...</option>
                <option value="maritimo">🚢 Marítimo</option>
                <option value="aereo">✈️ Aéreo</option>
                <option value="terrestre">🚛 Terrestre</option>
              </select>
            </div>

            <!-- Campos Condicionales: Marítimo -->
            <div id="ship-maritimo" class="conditional-fields" style="display: none;">
                <div class="form-group">
                  <label for="seaType">Modalidad Marítima *</label>
                  <select id="seaType" name="07_Detalle_Maritimo">
                    <option value="">Seleccione...</option>
                    <option value="FCL (Contenedor Completo)">FCL (Contenedor Completo)</option>
                    <option value="LCL (Consolidado)">LCL (Consolidado)</option>
                  </select>
                </div>
            </div>

            <!-- Campos Condicionales: Aéreo -->
            <div id="ship-aereo" class="conditional-fields air-grid" style="display: none;">
                <div class="form-group">
                  <label for="airPieces">Número de piezas *</label>
                  <input type="text" id="airPieces" name="07_Aereo_Piezas" placeholder="Ej: 5 bultos" />
                </div>
                <div class="form-group">
                  <label for="airDimensions">Dimensiones (cm) *</label>
                  <input type="text" id="airDimensions" name="08_Aereo_Dimensiones" placeholder="Largo x Ancho x Alto" />
                </div>
                <div class="form-group">
                  <label for="airWeight">Peso Bruto Total (kg) *</label>
                  <input type="text" id="airWeight" name="09_Aereo_Peso_Kg" placeholder="0 kg" />
                </div>
                <p class="help-text">💡 Si no tienes medidas exactas, puedes estimar.</p>
            </div>

            <!-- Campos Condicionales: Terrestre -->
            <div id="ship-terrestre" class="conditional-fields land-grid" style="display: none;">
                <div class="form-group">
                  <label for="landType">Modalidad Terrestre *</label>
                  <select id="landType" name="07_Terrestre_Modalidad">
                    <option value="">Seleccione...</option>
                    <option value="FTL (Camión Completo)">FTL (Camión Completo)</option>
                    <option value="LTL (Carga Parcial)">LTL (Carga Parcial)</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="truckType">Tipo de Camión *</label>
                  <select id="truckType" name="08_Terrestre_Tipo_Camion">
                    <option value="">Seleccione...</option>
                    <option value="Rampla">Rampla</option>
                    <option value="Sider">Sider</option>
                    <option value="Refrigerado">Refrigerado</option>
                    <option value="Plataforma">Plataforma</option>
                  </select>
                </div>
            </div>

            <div class="form-group">
              <label for="cargoType">Tipo de Carga *</label>
              <select id="cargoType" name="10_Tipo_Carga" required>
                <option value="">Seleccione...</option>
                <option value="Maquinaria Pesada">🏗️ Maquinaria Pesada</option>
                <option value="Construcción">🧱 Materiales de Construcción</option>
                <option value="Minería">⛏️ Equipos Mineros</option>
                <option value="Agrícola">🌾 Maquinaria Agrícola</option>
                <option value="Industrial">🏭 Equipos Industriales</option>
                <option value="Otro">📦 Otro</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="serviceType">Tipo de Servicio *</label>
              <select id="serviceType" name="11_Tipo_Servicio" required>
                <option value="">Seleccione...</option>
                <option value="Puerta a Puerta">🏠 Puerta a Puerta</option>
                <option value="Puerta a Puerto">🛳️ Puerta a Puerto</option>
                <option value="Puerto a Puerto">⚓ Puerto a Puerto</option>
                <option value="Puerto a Puerta">🏗️ Puerto a Puerta</option>
              </select>
            </div>

            <div id="general-weight" class="form-group">
              <label for="weight">Peso *</label>
              <input type="number" id="weight" name="12_Peso_Toneladas" min="0" step="0.1" required placeholder="0.0" />
            </div>

            <div class="form-group full-width">
              <label for="details">Detalles Adicionales</label>
              <textarea id="details" name="13_Detalles_Adicionales" rows="3" placeholder="Dimensiones, fechas, etc."></textarea>
            </div>
          </div>
          
          <!-- Anti-spam Honeypot -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div class="form-footer">
            <button type="submit" class="btn-submit">
              <span>Enviar Cotización</span>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<!-- Librerías para generación de PDF y envío de Email -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script is:inline>
  // Inicializar EmailJS globalmente
  (function() {
    if (window.emailjs) {
      window.emailjs.init("JH5nemZkYaM-rE3iS");
    }
  })();
</script>

<style>
  .quote-page {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    padding: 8rem 0 4rem;
  }

  .quote-background {
    position: fixed;
    inset: 0;
    background-color: #012e72ff;
    z-index: -2;
  }

  .quote-background::after {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.05) 0%, transparent 50%);
  }

  .quote-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
    width: 100%;
  }

  .quote-step {
    display: none;
  }

  .quote-step.active {
    display: block;
  }

  .step-header {
    text-align: center;
    margin-bottom: 2.5rem;
    color: white;
  }

  .step-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: white;
    letter-spacing: -1px;
  }

  .step-header p {
    font-size: 1.1rem;
    opacity: 0.9;
  }

  .highlight {
    color: #FFD700;
    font-weight: 700;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.1);
    color: white;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0.6rem 1.2rem;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .back-button:hover {
    background: rgba(255,255,255,0.2);
    transform: translateX(-3px);
  }

  .countries-selector {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .country-option {
    background: white;
    border: 2px solid transparent;
    padding: 1.5rem;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  .country-option:hover {
    transform: translateY(-5px);
    border-color: #1e3a8a;
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  .country-flag {
    font-size: 2.5rem;
  }

  .country-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e293b;
  }

  .country-arrow {
    color: #1e3a8a;
    opacity: 0.5;
  }

  .quote-form {
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  label {
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #334155;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  input, select, textarea {
    padding: 0.85rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #f8fafc;
    color: #1e293b;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: #1e3a8a;
    box-shadow: 0 0 0 3px rgba(30,58,138,0.1);
    background: white;
  }

  textarea {
    resize: vertical;
    min-height: 80px;
  }

  select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%231e3a8a' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .form-footer {
    margin-top: 2rem;
  }

  .btn-submit {
    width: 100%;
    background: #1e3a8a;
    color: white;
    padding: 1.1rem;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .btn-submit:hover {
    background: #1e40af;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .quote-page {
      padding: 6rem 0 2rem;
    }

    .step-header h1 {
      font-size: 2.2rem;
    }

    .countries-selector {
      grid-template-columns: 1fr;
    }

    .country-option {
      flex-direction: row;
      padding: 1rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .quote-form {
      padding: 1.5rem;
    }
  }

  /* Estilos para campos condicionales */
  .conditional-fields {
    grid-column: 1 / -1; /* Ocupar todo el ancho */
    background: #f1f5f9;
    padding: 1.5rem;
    border-radius: 12px;
    border: 2px dashed #1e3a8a;
    margin-bottom: 1rem;
    display: grid;
    gap: 1.25rem;
    animation: fadeInDown 0.4s ease-out;
  }

  .air-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .land-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .help-text {
    grid-column: 1 / -1;
    font-size: 0.85rem;
    color: #1e3a8a;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .air-grid, .land-grid, .conditional-fields {
      grid-template-columns: 1fr;
    }
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  let selectedDestination = '';

  document.addEventListener('DOMContentLoaded', () => {
    const step1 = document.getElementById('step1');
    const step2 = document.getElementById('step2');
    const countryOptions = document.querySelectorAll('.country-option');
    const backBtn = document.getElementById('backBtn');
    const selectedCountrySpan = document.getElementById('selectedCountry');
    const quoteForm = document.getElementById('quoteForm') as HTMLFormElement;
    const shippingType = document.getElementById('shippingType') as HTMLSelectElement;

    // Lógica de campos condicionales
    shippingType?.addEventListener('change', () => {
      const selected = shippingType.value;
      const allConditional = document.querySelectorAll('.conditional-fields') as NodeListOf<HTMLElement>;
      const generalWeight = document.getElementById('general-weight');

      allConditional.forEach(el => {
        el.style.display = 'none';
        el.querySelectorAll('input, select').forEach(input => {
          (input as HTMLInputElement | HTMLSelectElement).required = false;
        });
      });

      if (selected) {
        const target = document.getElementById(`ship-${selected}`);
        if (target) {
          target.style.display = 'block';
          target.querySelectorAll('input, select').forEach(input => {
            (input as HTMLInputElement | HTMLSelectElement).required = true;
          });
        }

        // Ocultar peso general si es Aéreo
        if (generalWeight) {
          if (selected === 'aereo') {
            generalWeight.style.display = 'none';
            (generalWeight.querySelector('input') as HTMLInputElement).required = false;
          } else {
            generalWeight.style.display = 'block';
            (generalWeight.querySelector('input') as HTMLInputElement).required = true;
          }
        }
      }
    });

    countryOptions.forEach(option => {
      option.addEventListener('click', () => {
        const countryCode = option.getAttribute('data-country');
        const countryName = option.querySelector('.country-name')?.textContent;
        const countryFlag = option.querySelector('.country-flag')?.textContent;
        
        selectedDestination = countryName || countryCode || '';
        if (selectedCountrySpan && countryName && countryFlag) {
          selectedCountrySpan.textContent = `${countryFlag} ${countryName}`;
        }
        
        step1?.classList.remove('active');
        step2?.classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    backBtn?.addEventListener('click', () => {
      step2?.classList.remove('active');
      step1?.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    quoteForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const rawFormData = new FormData(quoteForm);
      const button = quoteForm.querySelector('.btn-submit') as HTMLButtonElement;
      const originalContent = button.innerHTML;

      if (rawFormData.get('botcheck')) return;

      const seguimientoID = Math.random().toString(36).substr(2, 9).toUpperCase();

      const dataGrouped = {
        empresa: rawFormData.get('01_Empresa'),
        contacto: rawFormData.get('02_Contacto'),
        email: rawFormData.get('03_Email'),
        telefono: rawFormData.get('04_Telefono'),
        origen: rawFormData.get('05_Pais_Origen'),
        destino: selectedDestination,
        transporte: rawFormData.get('06_Tipo_Transporte'),
        carga: rawFormData.get('10_Tipo_Carga'),
        servicio: rawFormData.get('11_Tipo_Servicio'),
        peso_ton: rawFormData.get('12_Peso_Toneladas') || 'N/A',
        aereo_piezas: rawFormData.get('07_Aereo_Piezas') || '',
        aereo_dimensiones: rawFormData.get('08_Aereo_Dimensiones') || '',
        aereo_peso_kg: rawFormData.get('09_Aereo_Peso_Kg') || '',
        maritimo_modalidad: rawFormData.get('07_Detalle_Maritimo') || '',
        terrestre_modalidad: rawFormData.get('07_Terrestre_Modalidad') || '',
        terrestre_camion: rawFormData.get('08_Terrestre_Tipo_Camion') || '',
        comentarios: rawFormData.get('13_Detalles_Adicionales') || "Sin comentarios adicionales.",
        seguimiento_id: seguimientoID
      };

      button.disabled = true;
      button.innerHTML = '<span>Enviando...</span>';

      const serviceID = 'service_1443jv8';
      const templateID = 'template_hrl8yys';
      const publicKey = 'JH5nemZkYaM-rE3iS';
      const customFromName = `COTIZACION: ${dataGrouped.origen} -> ${dataGrouped.destino}`;

      // Enviar Email con Promesa para mayor compatibilidad en móviles
      (window as any).emailjs.send(serviceID, templateID, {
        ...dataGrouped,
        from_name: customFromName
      }, publicKey)
      .then(function(response) {
        if (response.status !== 200) throw new Error("Status " + response.status);

        // Éxito en Email, ahora PDF
        try {
          const { jsPDF } = (window as any).jspdf;
          const doc = new jsPDF();
          
          // 1. Cabecera (Navy Blue background)
          doc.setFillColor(30, 58, 138); // Brand Primary Navy Blue
          doc.rect(0, 0, 210, 38, 'F');
          
          // Línea dorada de acento
          doc.setFillColor(255, 215, 0); // Accent Gold
          doc.rect(0, 38, 210, 3, 'F');
          
          // Textos en Cabecera
          doc.setTextColor(255, 255, 255);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(24);
          doc.text("ShipLog", 15, 24);
          
          doc.setFont("helvetica", "normal");
          doc.setFontSize(9);
          doc.setTextColor(220, 225, 235);
          doc.text("SOLUCIONES LOGÍSTICAS DE CARGA PESADA", 15, 30);
          
          doc.setTextColor(255, 255, 255);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(13);
          doc.text("RESUMEN DE SOLICITUD", 195, 24, { align: "right" });
          
          doc.setFont("helvetica", "normal");
          doc.setFontSize(9);
          doc.setTextColor(220, 225, 235);
          doc.text("SUDAMÉRICA", 195, 30, { align: "right" });
          
          // 2. Metadatos de la Solicitud
          doc.setTextColor(51, 65, 85); // Slate 700
          doc.setFont("helvetica", "bold");
          doc.setFontSize(10);
          doc.text("CÓDIGO DE SEGUIMIENTO:", 15, 52);
          
          doc.setTextColor(30, 58, 138); // Navy
          doc.setFont("helvetica", "bold");
          doc.setFontSize(11);
          doc.text(seguimientoID, 65, 52);
          
          doc.setTextColor(100, 116, 139); // Slate 500
          doc.setFont("helvetica", "normal");
          doc.setFontSize(10);
          const fechaActual = new Date().toLocaleDateString('es-ES', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          });
          doc.text(`Fecha de Emisión: ${fechaActual}`, 195, 52, { align: "right" });
          
          // Línea divisoria sutil
          doc.setDrawColor(226, 232, 240);
          doc.setLineWidth(0.5);
          doc.line(15, 57, 195, 57);
          
          // 3. Preparación de Filas para Tablas
          const clientRows = [
            ["Empresa", dataGrouped.empresa || "N/A"],
            ["Contacto de Solicitud", dataGrouped.contacto || "N/A"],
            ["Correo Electrónico", dataGrouped.email || "N/A"],
            ["Teléfono de Contacto", dataGrouped.telefono || "N/A"]
          ];
          
          const getTransportLabel = (t) => {
            if (t === 'maritimo') return 'Marítimo 🚢';
            if (t === 'aereo') return 'Aéreo ✈️';
            if (t === 'terrestre') return 'Terrestre 🚛';
            return t;
          };
          
          const shippingRows = [
            ["Origen del Envío", dataGrouped.origen || "N/A"],
            ["Destino del Envío", dataGrouped.destino || "N/A"],
            ["Tipo de Transporte", getTransportLabel(dataGrouped.transporte)],
            ["Tipo de Carga", dataGrouped.carga || "N/A"],
            ["Tipo de Servicio", dataGrouped.servicio || "N/A"]
          ];
          
          if (dataGrouped.transporte === 'maritimo') {
            shippingRows.push(["Modalidad Marítima", dataGrouped.maritimo_modalidad || "N/A"]);
            shippingRows.push(["Peso Bruto Estimado", `${dataGrouped.peso_ton} Toneladas`]);
          } else if (dataGrouped.transporte === 'terrestre') {
            shippingRows.push(["Modalidad Terrestre", dataGrouped.terrestre_modalidad || "N/A"]);
            shippingRows.push(["Tipo de Vehículo / Camión", dataGrouped.terrestre_camion || "N/A"]);
            shippingRows.push(["Peso Bruto Estimado", `${dataGrouped.peso_ton} Toneladas`]);
          } else if (dataGrouped.transporte === 'aereo') {
            shippingRows.push(["Cantidad de Bultos / Piezas", dataGrouped.aereo_piezas || "N/A"]);
            shippingRows.push(["Dimensiones Totales", dataGrouped.aereo_dimensiones || "N/A"]);
            shippingRows.push(["Peso Total Declarado", `${dataGrouped.aereo_peso_kg} Kg`]);
          }
          
          // 4. Tabla 1: Datos del Cliente (jspdf-autotable)
          (doc as any).autoTable({
            startY: 63,
            theme: 'grid',
            head: [['CONCEPTOS - CLIENTE', 'DETALLES']],
            body: clientRows,
            styles: { 
              font: 'helvetica', 
              fontSize: 9.5, 
              cellPadding: 4.5,
              valign: 'middle'
            },
            headStyles: { 
              fillColor: [30, 58, 138], 
              textColor: [255, 255, 255], 
              fontStyle: 'bold',
              fontSize: 10
            },
            columnStyles: {
              0: { fontStyle: 'bold', width: 55, fillColor: [248, 250, 252] },
              1: { fillColor: [255, 255, 255] }
            },
            gridLineColor: [226, 232, 240],
            lineWidth: 0.5
          });
          
          let nextY = (doc as any).lastAutoTable.finalY + 8;
          
          // 5. Tabla 2: Detalles del Envío (jspdf-autotable)
          (doc as any).autoTable({
            startY: nextY,
            theme: 'grid',
            head: [['DETALLES DE LA CARGA', 'VALORES']],
            body: shippingRows,
            styles: { 
              font: 'helvetica', 
              fontSize: 9.5, 
              cellPadding: 4.5,
              valign: 'middle'
            },
            headStyles: { 
              fillColor: [30, 58, 138], 
              textColor: [255, 255, 255], 
              fontStyle: 'bold',
              fontSize: 10
            },
            columnStyles: {
              0: { fontStyle: 'bold', width: 55, fillColor: [248, 250, 252] },
              1: { fillColor: [255, 255, 255] }
            },
            gridLineColor: [226, 232, 240],
            lineWidth: 0.5
          });
          
          nextY = (doc as any).lastAutoTable.finalY + 8;
          
          // 6. Sección de Comentarios
          doc.setFillColor(248, 250, 252);
          doc.setDrawColor(226, 232, 240);
          doc.setLineWidth(0.5);
          
          const commentText = "Detalles y Requerimientos Adicionales:\n" + dataGrouped.comentarios;
          const splitComment = doc.splitTextToSize(commentText, 170);
          const boxHeight = (splitComment.length * 5.5) + 12;
          
          // Dibujar caja contenedora
          doc.rect(15, nextY, 180, boxHeight, 'FD');
          
          // Dibujar línea de acento izquierda
          doc.setFillColor(30, 58, 138);
          doc.rect(15, nextY, 2.5, boxHeight, 'F');
          
          // Imprimir texto de comentarios
          doc.setTextColor(51, 65, 85);
          doc.setFontSize(9.5);
          doc.setFont('helvetica', 'normal');
          doc.text(splitComment, 23, nextY + 7.5);
          
          // 7. Pie de Página Fijo
          doc.setDrawColor(226, 232, 240);
          doc.setLineWidth(0.5);
          doc.line(15, 272, 195, 272);
          
          doc.setTextColor(148, 163, 184); // Slate 400
          doc.setFontSize(8);
          doc.text("Este es un comprobante oficial de su solicitud de cotización registrada en nuestro sistema.", 105, 278, { align: "center" });
          doc.setTextColor(100, 116, 139); // Slate 500
          doc.setFontSize(8.5);
          doc.text("ShipLog SpA • Los Andes, Chile • logistica.global@shiplog.cl • www.shiplog.cl", 105, 284, { align: "center" });
          
          // Guardar PDF
          doc.save(`ShipLog_Cotizacion_${seguimientoID}.pdf`);
        } catch (pdfErr) {
          console.error("Error PDF:", pdfErr);
        }

        button.innerHTML = '<span>✓ ¡Enviado!</span>';
        button.style.background = '#37B34A';
        
        setTimeout(() => {
          alert('¡Gracias! Su solicitud ha sido enviada correctamente.');
          window.location.href = '/';
        }, 1000);
      })
      .catch(function(error) {
        console.error("Fallo EmailJS:", error);
        const errorDetail = error.text || error.message || 'Error de conexión';
        alert('Error al enviar: ' + errorDetail + '. Por favor intente de nuevo o escriba a logistica.global@shiplog.cl');
        button.innerHTML = originalContent;
        button.disabled = false;
      });
    });
  });
</script>
