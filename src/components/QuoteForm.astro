---
---

<section id="cotizador" class="quote-form">
  <div class="container">
    <h2 class="fade-in">Solicitar Cotización</h2>
    <p class="section-subtitle fade-in">Complete el formulario y nos contactaremos con usted en menos de 24 horas</p>
    
    <form class="form scale-in" id="quoteForm">
      <div class="form-sections">
        <!-- Sección 1: Datos de Contacto -->
        <div class="form-section-block">
          <h3 class="form-section-title">
            <span class="title-icon">👤</span> Datos de Contacto
          </h3>
          <div class="form-grid">
            <div class="form-group">
              <label for="company">Empresa *</label>
              <input type="text" id="company" name="company" required placeholder="Nombre de su empresa" />
            </div>
            
            <div class="form-group">
              <label for="contact">Nombre de Contacto *</label>
              <input type="text" id="contact" name="contact" required placeholder="Su nombre completo" />
            </div>
            
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="correo@empresa.com" />
            </div>
            
            <div class="form-group">
              <label for="phone">Teléfono *</label>
              <input type="tel" id="phone" name="phone" required placeholder="+XX XXX XXX XXXX" />
            </div>
          </div>
        </div>

        <!-- Sección 2: Detalles del Envío -->
        <div class="form-section-block">
          <h3 class="form-section-title">
            <span class="title-icon">📦</span> Detalles del Envío
          </h3>
          <div class="form-grid">
            <div class="form-group full-width">
              <label for="shippingType">Tipo de Envío *</label>
              <select id="shippingType" name="shippingType" required>
                <option value="">Seleccione...</option>
                <option value="maritimo">🚢 Marítimo</option>
                <option value="aereo">✈️ Aéreo</option>
                <option value="terrestre">🚛 Terrestre</option>
              </select>
            </div>

            <!-- Campos Condicionales: Marítimo -->
            <div id="ship-maritimo" class="conditional-fields full-width" style="display: none;">
              <div class="form-grid">
                <div class="form-group">
                  <label for="seaType">Modalidad Marítima *</label>
                  <select id="seaType" name="seaType">
                    <option value="">Seleccione...</option>
                    <option value="fcl">FCL (Contenedor Completo)</option>
                    <option value="lcl">LCL (Consolidado)</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Campos Condicionales: Aéreo -->
            <div id="ship-aereo" class="conditional-fields full-width" style="display: none;">
              <div class="form-grid">
                <div class="form-group">
                  <label for="airPieces">Número de piezas *</label>
                  <input type="text" id="airPieces" name="airPieces" placeholder="Ej: 5 bultos" />
                </div>
                <div class="form-group">
                  <label for="airDimensions">Dimensiones (cm) *</label>
                  <input type="text" id="airDimensions" name="airDimensions" placeholder="Largo x Ancho x Alto" />
                </div>
                <div class="form-group">
                  <label for="airWeight">Peso Bruto Total (kg) *</label>
                  <input type="text" id="airWeight" name="airWeight" placeholder="0 kg" />
                </div>
                <p class="help-text">💡 Si no tienes medidas exactas, puedes estimar.</p>
              </div>
            </div>

            <!-- Campos Condicionales: Terrestre -->
            <div id="ship-terrestre" class="conditional-fields full-width" style="display: none;">
              <div class="form-grid">
                <div class="form-group">
                  <label for="landType">Modalidad Terrestre *</label>
                  <select id="landType" name="landType">
                    <option value="">Seleccione...</option>
                    <option value="ftl">FTL (Camión Completo)</option>
                    <option value="ltl">LTL (Carga Parcial)</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="truckType">Tipo de Camión *</label>
                  <select id="truckType" name="truckType">
                    <option value="">Seleccione...</option>
                    <option value="rampla">Rampla</option>
                    <option value="sider">Sider</option>
                    <option value="refrigerado">Refrigerado</option>
                    <option value="plataforma">Plataforma</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="origin">País de Origen *</label>
              <select id="origin" name="origin" required>
                <option value="">Seleccione...</option>
                <option value="argentina">🇦🇷 Argentina</option>
                <option value="brasil">🇧🇷 Brasil</option>
                <option value="chile">🇨🇱 Chile</option>
                <option value="ecuador">🇪🇨 Ecuador</option>
                <option value="paraguay">🇵🇾 Paraguay</option>
                <option value="peru">🇵🇪 Perú</option>
                <option value="uruguay">🇺🇾 Uruguay</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="destination">País de Destino *</label>
              <select id="destination" name="destination" required>
                <option value="">Seleccione...</option>
                <option value="argentina">🇦🇷 Argentina</option>
                <option value="brasil">🇧🇷 Brasil</option>
                <option value="chile">🇨🇱 Chile</option>
                <option value="ecuador">🇪🇨 Ecuador</option>
                <option value="paraguay">🇵🇾 Paraguay</option>
                <option value="peru">🇵🇪 Perú</option>
                <option value="uruguay">🇺🇾 Uruguay</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="cargoType">Tipo de Carga *</label>
              <select id="cargoType" name="cargoType" required>
                <option value="">Seleccione...</option>
                <option value="maquinaria">🏗️ Maquinaria Pesada</option>
                <option value="construccion">🧱 Materiales de Construcción</option>
                <option value="mineria">⛏️ Equipos Mineros</option>
                <option value="agricola">🌾 Maquinaria Agrícola</option>
                <option value="industrial">🏭 Equipos Industriales</option>
                <option value="otro">📦 Otro</option>
              </select>
            </div>

            <div id="general-weight" class="form-group">
              <label for="weight">Peso Estimado (Toneladas) *</label>
              <input type="number" id="weight" name="weight" min="0" step="0.1" required placeholder="0.0" />
            </div>
          </div>
        </div>
      </div>
      
      <div class="form-group full-width" style="margin-top: 1.5rem;">
        <label for="details">Detalles Adicionales</label>
        <textarea id="details" name="details" rows="4" placeholder="Describa su carga, dimensiones especiales, fechas requeridas, etc."></textarea>
      </div>
      
      <!-- Anti-spam Honeypot -->
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
      
      <div class="form-footer">
        <button type="submit" class="btn-submit">
          <span>Enviar Solicitud</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <p class="form-note">Sus datos están protegidos y serán utilizados únicamente para procesar su solicitud</p>
      </div>
    </form>
  </div>
</section>

<style>
  .quote-form {
    background: white;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.2rem;
    color: var(--gray);
    margin-bottom: 4rem;
  }

  .form {
    max-width: 1000px;
    margin: 0 auto;
    background: white;
    padding: 3.5rem;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(0,102,255,0.1);
    border: 2px solid rgba(0,102,255,0.1);
  }

  .form-sections {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .form-section-block {
    background: #f8fafc;
    padding: 2rem;
    border-radius: 18px;
    border: 1px solid #e2e8f0;
  }

  .form-section-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 2px solid #e2e8f0;
    padding-bottom: 0.75rem;
  }

  .title-icon {
    background: white;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    font-size: 1.2rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  label {
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--dark);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  input, select, textarea {
    padding: 1rem 1.25rem;
    border: 2px solid var(--light);
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: white;
    color: var(--dark);
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(0,102,255,0.1);
  }

  input::placeholder, textarea::placeholder {
    color: var(--gray);
    opacity: 0.6;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
    min-height: 120px;
  }

  select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%230066FF' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 3rem;
  }

  .form-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .btn-submit {
    width: 100%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    padding: 1.2rem 3rem;
    border: none;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    box-shadow: 0 10px 30px rgba(0,102,255,0.3);
  }

  .btn-submit:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0,102,255,0.4);
  }

  .btn-submit:active {
    transform: translateY(-1px);
  }

  .form-note {
    font-size: 0.9rem;
    color: var(--gray);
    text-align: center;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .form {
      padding: 2rem 1.5rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .form-section-block {
      padding: 1.5rem;
    }
  }

  /* Estilos para campos condicionales */
  .conditional-fields {
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    border: 2px dashed var(--primary);
    margin-top: 0.5rem;
    animation: fadeInDown 0.4s ease-out;
  }

  .help-text {
    grid-column: 1 / -1;
    font-size: 0.85rem;
    color: var(--primary);
    font-style: italic;
    margin-top: -0.5rem;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const quoteForm = document.getElementById('quoteForm') as HTMLFormElement;
  const shippingType = document.getElementById('shippingType') as HTMLSelectElement;
  
  // Logic for conditional fields
  shippingType?.addEventListener('change', () => {
    const selected = shippingType.value;
    
    // Hide all
    const allConditional = document.querySelectorAll('.conditional-fields') as NodeListOf<HTMLElement>;
    allConditional.forEach(el => {
      el.style.display = 'none';
      // Remove required from inner inputs
      el.querySelectorAll('input, select').forEach(input => {
        (input as HTMLInputElement | HTMLSelectElement).required = false;
      });
    });

    // Show selected
    if (selected) {
      const target = document.getElementById(`ship-${selected}`);
      const generalWeight = document.getElementById('general-weight');
      
      if (target) {
        target.style.display = 'block';
        // Add required to inner inputs
        target.querySelectorAll('input, select').forEach(input => {
          (input as HTMLInputElement | HTMLSelectElement).required = true;
        });
      }

      // Hide general weight if Aereo is selected (since it has its own Kg field)
      if (generalWeight) {
        if (selected === 'aereo') {
          generalWeight.style.display = 'none';
          (generalWeight.querySelector('input') as HTMLInputElement).required = false;
        } else {
          generalWeight.style.display = 'block';
          (generalWeight.querySelector('input') as HTMLInputElement).required = true;
        }
      }
    }
  });

  quoteForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(quoteForm);
    const button = quoteForm.querySelector('.btn-submit') as HTMLButtonElement;
    const originalContent = button.innerHTML;
    
    // Web3Forms configuration
    // IMPORTANT: Replace with your actual Access Key from https://web3forms.com/
    formData.append("access_key", "713b4fe9-be8b-4e04-b3bf-3509e7d2dc65");
    formData.append("from_name", "ShipLog Web - Cotización");
    formData.append("subject", `Nueva Cotización de ${formData.get('company')}`);

    try {
      button.disabled = true;
      button.innerHTML = '<span>Enviando...</span>';
      
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData
      });

      const result = await response.json();

      if (result.success) {
        // Succes state
        button.innerHTML = '<span>✓ ¡Enviado con éxito!</span>';
        button.style.background = '#37B34A';
        
        setTimeout(() => {
          alert('¡Gracias por su solicitud! Nos pondremos en contacto con usted en menos de 24 horas.');
          quoteForm.reset();
          button.innerHTML = originalContent;
          button.style.background = '';
          button.disabled = false;
        }, 2000);
      } else {
        throw new Error(result.message);
      }
    } catch (error) {
      console.error(error);
      alert('Hubo un error al enviar el formulario. Por favor, intente nuevamente o contáctenos directamente.');
      button.innerHTML = originalContent;
      button.disabled = false;
    }
  });
</script>
